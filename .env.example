# ─────────────────────────────────────────────────────────────
# llm-wiki-kit configuration
# Copy this file to `.env` and fill in your paths.
# `wiki-setup` reads these values when initializing a vault.
#
# Vault resolution precedence (highest first):
#   1. OBSIDIAN_VAULT_PATH environment variable (per-session override)
#   2. a .env at the current working directory / vault root (vault-scoped)
#   3. ~/.obsidian-wiki/config (global default, written by install.sh)
# To scope a single vault: drop a copy of this file (as `.env`) at that
# vault's root with OBSIDIAN_VAULT_PATH pointing at itself.
# ─────────────────────────────────────────────────────────────

# REQUIRED — where the wiki vault lives (absolute path, after ~ expansion).
# This is the Obsidian vault the skills read from and write to.
OBSIDIAN_VAULT_PATH="$HOME/Documents/my-wiki"

# OPTIONAL — where your raw source documents live (articles, PDFs, notes,
# screenshots). Comma-separated for multiple locations. `wiki-ingest` reads these.
OBSIDIAN_SOURCES_DIR="$HOME/Documents"

# OPTIONAL — staging folder inside the vault for rough drafts that
# `wiki-ingest` promotes into proper pages, then deletes the original.
OBSIDIAN_RAW_DIR="raw"

# OPTIONAL — category vocabulary. Two layouts are supported:
#   1. Flat (recommended, what the starter template uses): a single `notes/`
#      folder, category expressed via frontmatter `category: <value>`.
#   2. Folders: one directory per category (concepts/, entities/, ...).
# This list is the allowed `category` values either way.
OBSIDIAN_CATEGORIES="concept,entity,reference,insight,synthesis"

# ─────────────────────────────────────────────────────────────
# QMD — optional local search engine (BM25 + vector). Skills fall back to
# Grep automatically if these are unset or qmd is not installed.
# Install + index in one step:  ./setup-qmd.sh
# Or manually:  npm install -g @tobilu/qmd
#               qmd collection add "$OBSIDIAN_VAULT_PATH" --name wiki && qmd embed
# ─────────────────────────────────────────────────────────────
QMD_WIKI_COLLECTION="wiki"
# QMD_PAPERS_COLLECTION="papers"

# ─────────────────────────────────────────────────────────────
# Optional history ingestion (mine your AI coding sessions into the wiki).
# Used by claude-history-ingest / codex-history-ingest.
# ─────────────────────────────────────────────────────────────
# CLAUDE_HISTORY_PATH="$HOME/.claude"
# CODEX_HISTORY_PATH="$HOME/.codex"
